# MistralMind - Environment Variables
# Copy this to .env and fill in your actual values
# NEVER commit .env to git!

# Mistral API Key (get from console.mistral.ai)
MISTRAL_API_KEY="MISTRAL_API_KEY"

# Weights & Biases (https://wandb.ai/authorize)
WANDB_API_KEY="WANDB_API_KEY"
WANDB_PROJECT=mistralmind

# HuggingFace (optional - for pushing models/datasets)
HF_TOKEN="HF_TOKEN"
HF_USERNAME="HF_USERNAME"

# Model paths after fine-tuning (update these after training)
MEDICAL_MODEL_ID=mistral-small-latest
FINANCE_MODEL_ID=mistral-small-latest
CODE_MODEL_ID=codestral-latest
CREATIVE_MODEL_ID=mistral-small-latest
